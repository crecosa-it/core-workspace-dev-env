 FOREIGN KEY (`ID_TIPO_SOLICITUD`) REFERENCES `CR_TIPO_SOLICITUD` (`ID_TIPO_SOLICITUD`),\\n  CONSTRAINT `CR_SOLICITUD_ibfk_2` FOREIGN KEY (`ID_ESTADO`) REFERENCES `CR_ESTADO_SOLICITUD` (`ID_ESTADO`),\\n  CONSTRAINT `CR_SOLICITUD_ibfk_3` FOREIGN KEY (`ID_PRIORIDAD`) REFERENCES `CR_PRIORIDAD` (`ID_PRIORIDAD`),\\n  CONSTRAINT `FK_SOLICITUD_CREDITO` FOREIGN KEY (`CODIGO_CREDITO`) REFERENCES `CR_CREDITO_LINEA` (`CODIGO_CREDITO`) ON DELETE NO ACTION ON UPDATE CASCADE\\n) ENGINE=InnoDB AUTO_INCREMENT=79 DEFAULT CHARSET=latin1 COLLATE=latin1_swedish_ci\"\n    }\n  ],\n  \"affectedRows\": 0\n}"}]}
